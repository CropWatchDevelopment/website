{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "git": {
    "deploymentEnabled": {
      "master": false,
      "Japan-website": false
    }
  },
  "redirects": [
    {
      "source": "/pricing",
      "has": [{ "type": "header", "key": "x-vercel-ip-country", "value": "JP" }],
      "destination": "https://cropwatch.co.jp/pricing",
      "permanent": false
    },
    {
      "source": "/contact",
      "has": [{ "type": "header", "key": "x-vercel-ip-country", "value": "JP" }],
      "destination": "https://cropwatch.co.jp/contact",
      "permanent": false
    },
    {
      "source": "/cold-chain",
      "has": [{ "type": "header", "key": "x-vercel-ip-country", "value": "JP" }],
      "destination": "https://cropwatch.co.jp/cold-chain",
      "permanent": false
    },
    {
      "source": "/livestock",
      "has": [{ "type": "header", "key": "x-vercel-ip-country", "value": "JP" }],
      "destination": "https://cropwatch.co.jp/livestock",
      "permanent": false
    },
    {
      "source": "/agriculture",
      "has": [{ "type": "header", "key": "x-vercel-ip-country", "value": "JP" }],
      "destination": "https://cropwatch.co.jp/agriculture",
      "permanent": false
    },
    {
      "source": "/replacement-sensors",
      "has": [{ "type": "header", "key": "x-vercel-ip-country", "value": "JP" }],
      "destination": "https://cropwatch.co.jp/replacement-sensors",
      "permanent": false
    },
    {
      "source": "/news/:rest*",
      "has": [{ "type": "header", "key": "x-vercel-ip-country", "value": "JP" }],
      "destination": "https://cropwatch.co.jp/news",
      "permanent": false
    },
    {
      "source": "/news",
      "has": [{ "type": "header", "key": "x-vercel-ip-country", "value": "JP" }],
      "destination": "https://cropwatch.co.jp/news",
      "permanent": false
    },
    {
      "source": "/:path((?!149e9513-01fa-4fb0-aad4-566afd725d1b).*)",
      "has": [{ "type": "header", "key": "x-vercel-ip-country", "value": "JP" }],
      "destination": "https://cropwatch.co.jp/",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/149e9513-01fa-4fb0-aad4-566afd725d1b/2d206a39-8ed7-437e-a3be-862e0f06eea3/a-4-a/c.js",
      "destination": "https://api.vercel.com/bot-protection/v1/challenge"
    },
    {
      "source": "/149e9513-01fa-4fb0-aad4-566afd725d1b/2d206a39-8ed7-437e-a3be-862e0f06eea3/:path*",
      "destination": "https://api.vercel.com/bot-protection/v1/proxy/:path*"
    }
  ],
  "headers": [
    {
      "source": "/149e9513-01fa-4fb0-aad4-566afd725d1b/2d206a39-8ed7-437e-a3be-862e0f06eea3/:path*",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        }
      ]
    }
  ]
}
